{
  "name": "google",
  "description": "Google search, Gemini AI, and browser automation skills.",
  "version": "1.0.0",
  "author": {
    "name": "Austen Stone",
    "url": "https://github.com/austenstone"
  },
  "license": "MIT",
  "repository": "https://github.com/austenstone/.copilot",
  "keywords": ["google", "gemini", "search", "playwright", "browser"],
  "skills": [
    "skills/google-search",
    "skills/gemini-image",
    "skills/gemini-video",
    "skills/playwright"
  ],
  "agents": [],
  "mcpServers": {
    "notebooklm": {
      "type": "stdio",
      "command": "npx",
      "args": ["notebooklm-mcp@latest"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--autoConnect"]
    },
    "playwright-headless": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless", "--isolated"]
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server", "--transport", "stdio"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    }
  }
}
