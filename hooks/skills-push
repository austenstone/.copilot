#!/bin/sh
# Usage: hooks/skills-push [commit message]
MSG="${1:-update skill}"

cd "$(git rev-parse --show-toplevel)/skills" || exit 1

if ! git diff --quiet || ! git diff --cached --quiet; then
  git add -A && git commit -m "$MSG"
fi

git push

cd ..
git add skills
git diff --cached --quiet || git commit -m "chore: bump skills"
git push
