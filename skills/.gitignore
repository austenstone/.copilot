# Skill-local noise. Root .gitignore already whitelists skills/**,
# so new skill files are tracked by default. Only ignore generated/runtime junk.

.DS_Store
**/.DS_Store
node_modules/
**/node_modules/
*.log
**/*.log
__pycache__/
**/__pycache__/
outputs/
**/outputs/
profile/
**/profile/
google-search copy/
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.bak
*.enc
